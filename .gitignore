# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude terraform.tfvars and other sensitive files if needed
*.tfvars
*.tfvars.json

# Ignore override files as they are usually personal/temporary
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include plugin cache directory
.terraform.lock.hcl

# Ignore .terraform directory
.terraform/

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore specific sensitive files in this project
terraform_key
terraform_key.pub
*.pub
